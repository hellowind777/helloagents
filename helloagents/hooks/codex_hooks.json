{
  "_comment": "HelloAGENTS Codex Hooks. Deployed by installer.py → ~/.codex/hooks.json. {SCRIPTS_DIR} resolved at install time.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"{SCRIPTS_DIR}/check_config_quick.py\" --force",
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"{SCRIPTS_DIR}/session_end.py\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
