{
  "_comment": "HelloAGENTS Gemini CLI Hooks. Qwen Code reuses this file. Deployed via cli_adapters → settings.json.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "helloagents --check-update --silent",
            "timeout": 5,
            "description": "HelloAGENTS 版本更新提示"
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"{SCRIPTS_DIR}/inject_context.py\"",
            "timeout": 3,
            "description": "HelloAGENTS 上下文注入"
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"{SCRIPTS_DIR}/session_end.py\"",
            "async": false,
            "timeout": 10,
            "description": "HelloAGENTS KB 同步标志"
          },
          {
            "type": "command",
            "command": "python3 \"{SCRIPTS_DIR}/notify.py\" route",
            "async": false,
            "timeout": 5,
            "description": "HelloAGENTS 声音+桌面通知"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"{SCRIPTS_DIR}/pre_tool_guard.py\"",
            "timeout": 3,
            "description": "HelloAGENTS 危险命令安全防护"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"{SCRIPTS_DIR}/progress_snapshot.py\"",
            "async": true,
            "timeout": 10,
            "description": "HelloAGENTS 进度快照"
          }
        ]
      }
    ],
    "PreCompress": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"{SCRIPTS_DIR}/pre_compact.py\"",
            "async": false,
            "timeout": 10,
            "description": "HelloAGENTS 压缩前进度快照"
          }
        ]
      }
    ]
  }
}
