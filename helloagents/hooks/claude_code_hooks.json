{
  "_comment": "HelloAGENTS Claude Code Hooks. Deployed by installer.py → settings.json. {SCRIPTS_DIR} resolved at install time.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"{SCRIPTS_DIR}/check_config_quick.py\" --force",
            "timeout": 3,
            "description": "HelloAGENTS 配置完整性检测"
          },
          {
            "type": "command",
            "command": "helloagents --check-update --silent",
            "timeout": 5,
            "description": "HelloAGENTS 版本更新提示"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"{SCRIPTS_DIR}/inject_context.py\"",
            "timeout": 3,
            "description": "HelloAGENTS 主代理规则强化"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"{SCRIPTS_DIR}/inject_context.py\"",
            "timeout": 5,
            "description": "HelloAGENTS 子代理上下文注入"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "general-purpose",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"{SCRIPTS_DIR}/ralph_loop.py\"",
            "timeout": 120,
            "description": "HelloAGENTS 质量验证循环（Ralph Loop）"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"{SCRIPTS_DIR}/progress_snapshot.py\"",
            "async": false,
            "timeout": 10,
            "description": "HelloAGENTS 进度快照"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"{SCRIPTS_DIR}/session_end.py\"",
            "async": false,
            "timeout": 10,
            "description": "HelloAGENTS KB 同步标志"
          },
          {
            "type": "command",
            "command": "python3 \"{SCRIPTS_DIR}/notify.py\" route",
            "async": false,
            "timeout": 5,
            "description": "HelloAGENTS 智能声音路由"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"{SCRIPTS_DIR}/pre_compact.py\"",
            "async": false,
            "timeout": 10,
            "description": "HelloAGENTS 压缩前进度快照"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"{SCRIPTS_DIR}/pre_tool_guard.py\"",
            "timeout": 3,
            "description": "HelloAGENTS 危险命令安全防护"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"{SCRIPTS_DIR}/session_end.py\"",
            "async": false,
            "timeout": 10,
            "description": "HelloAGENTS 会话结束清理"
          }
        ]
      }
    ]
  }
}
